!/usr/bin/env bash
set -eEuo pipefail
log(){ echo "[$(date -Is)] $*"; }
ROOT="/home/site/wwwroot"
JOBDIR="$ROOT/App_Data/jobs/continuous/translator-worker"
SITEPKG="$ROOT/.python_packages/lib/site-packages"
LOGDIR="/home/LogFiles/WebJobs"
LOGFILE="$LOGDIR/translator-worker.out"
LOCKFILE="$ROOT/.run.lock"
DATADIR="/home/data/translator-worker"   # <-- SAFE AREA (bukan di JOBDIR)
PIDFILE="$DATADIR/worker.pid"            # <-- pindah dari $JOBDIR
REQHASH="$DATADIR/requirements.sha256"   # <-- pindah dari $ROOT/$JOBDIR
SHUTDOWN_FILE="${WEBJOBS_SHUTDOWN_FILE:-}"
mkdir -p "$LOGDIR" "$SITEPKG" "$DATADIR"
cd "$JOBDIR"
# semua stdout/stderr -> logfile (truncate in-place jika besar)
exec >>"$LOGFILE" 2>&1
log "=== WORKER STARTING === (pid $$)"
rotate_logs_if_big() {
  if [ -f "$LOGFILE" ]; then
    local size; size="$(wc -c < "$LOGFILE" 2>/dev/null || echo 0)"
    if [ "${size:-0}" -ge $((50*1024*1024)) ]; then
      : > "$LOGFILE"
      log "Rotated (truncate) $LOGFILE"
    fi
  fi
}
# ENV
export LANG=C.UTF-8 LC_ALL=C.UTF-8 HOME=/home
unset VIRTUAL_ENV || true
PATH="$(echo "$PATH" | awk -v RS=: -v ORS=: '($0!~/\/\.venv\// && $0!~/^\/tmp\//){print}' | sed 's/:$//')"
export PATH
PYTHONPATH="${PYTHONPATH:-}"
PYTHONPATH="$(echo "$PYTHONPATH" | awk -v RS=: -v ORS=: '($0!~/^\/tmp\//){print}' | sed 's/:$//')"
export PYTHONPATH="$SITEPKG:$ROOT:$JOBDIR"
export PYTHONUNBUFFERED=1
export PYTHONDONTWRITEBYTECODE=1
umask 002
# SINGLETON LOCK
exec 200>"$LOCKFILE"
if ! flock -n 200; then
  log "Another instance running"
  exit 0
fi
# REQUIREMENTS (hash disimpan di /home/data, bukan di JOBDIR)
REQ="$JOBDIR/requirements.txt"
if [ -f "$REQ" ]; then
  CURHASH="$(sha256sum "$REQ" | awk '{print $1}')"
  OLDHASH="$(cat "$REQHASH" 2>/dev/null || true)"
  if [ "$CURHASH" != "$OLDHASH" ]; then
    log "Installing requirements..."
    python -m pip install --upgrade pip wheel >/dev/null 2>&1 || true
    python -m pip install --no-cache-dir -r "$REQ" --target "$SITEPKG" --root-user-action=ignore
    echo "$CURHASH" > "$REQHASH"
    log "Installation complete"
  else
    log "Requirements unchanged"
  fi
else
  python -m pip install --upgrade pip wheel >/dev/null 2>&1 || true
  python -m pip install --no-cache-dir httpx azure-storage-queue azure-storage-blob SQLAlchemy --target "$SITEPKG" --root-user-action=ignore || true
fi
# VERIF MODUL (jangan touch file di JOBDIR)
python - <<'PY'
import sys, importlib.util, os
print("Python:", sys.version.split()[0]); print("CWD:", os.getcwd())
ok1 = importlib.util.find_spec("worker.worker") is not None
ok2 = importlib.util.find_spec("worker.worker.worker") is not None
print(("✓" if ok1 else "✗"), "worker.worker ->", getattr(importlib.util.find_spec("worker.worker"), "origin", "NOT FOUND") if ok1 else "NOT FOUND")
print(("✓" if ok2 else "✗"), "worker.worker.worker ->", getattr(importlib.util.find_spec("worker.worker.worker"), "origin", "NOT FOUND") if ok2 else "NOT FOUND")
sys.exit(0 if (ok1 and ok2) else 1)
PY
# CLEANUP / REAP
WPID=""; WPGRP=""
cleanup() {
  log "CLEANUP: stopping worker PID=${WPID:-'-'} PGID=${WPGRP:-'-'}"
  if [ -n "${WPGRP:-}" ]; then kill -TERM -"${WPGRP}" 2>/dev/null || true
  elif [ -n "${WPID:-}" ]; then kill -TERM "${WPID}" 2>/dev/null || true; fi
  for _ in {1..10}; do [ -n "${WPID:-}" ] && kill -0 "${WPID}" 2>/dev/null || break; sleep 0.5; done
  if [ -n "${WPID:-}" ] && kill -0 "${WPID}" 2>/dev/null; then
    if [ -n "${WPGRP:-}" ]; then kill -KILL -"${WPGRP}" 2>/dev/null || true; else kill -KILL "${WPID}" 2>/dev/null || true; fi
  fi
  [ -n "${WPID:-}" ] && wait "${WPID}" 2>/dev/null || true
  log "CLEANUP done"
}
trap cleanup EXIT INT TERM
trap 'log "ERR line ${LINENO} status=$?"' ERR
# AUTO-RESTART MONITOR
STALL_SEC="${STALL_SEC:-1200}"
CHECK_EVERY="${CHECK_EVERY:-30}"
BACKOFF="${BACKOFF:-5}"
DRAIN_ON_SHUTDOWN_SEC="${DRAIN_ON_SHUTDOWN_SEC:-120}"
start_worker() {
  log "Launching worker..."
  if command -v setsid >/dev/null 2>&1; then
    setsid python -u -m worker.worker.worker &
  else
    python -u -m worker.worker.worker &
  fi
  WPID=$!
  WPGRP="$(ps -o pgid= -p "$WPID" 2>/dev/null | tr -d ' ' || true)"
  echo "$WPID" > "$PIDFILE"          # <-- simpan di /home/data
  log "Worker PID=$WPID PGID=${WPGRP:-unknown}"
}
start_worker
last_polls=""; last_change_epoch="$(date -u +%s)"
read_last_heartbeat() {
  tail -n 4000 "$LOGFILE" 2>/dev/null \
    | grep -a '"msg": "heartbeat"' \
    | grep -a "\"pid\": $WPID" \
    | tail -n 1 || true
}
while :; do
  # Graceful stop dari platform
  if [ -n "$SHUTDOWN_FILE" ] && [ -f "$SHUTDOWN_FILE" ]; then
    ts="$(/usr/bin/stat --format='%y' "$SHUTDOWN_FILE" 2>/dev/null || /bin/date -Is)"
    log "Shutdown file detected at ${ts} -> draining up to ${DRAIN_ON_SHUTDOWN_SEC}s"
    for _ in $(seq 1 "$DRAIN_ON_SHUTDOWN_SEC"); do
      kill -0 "$WPID" 2>/dev/null || break
      sleep 1
    done
    log "Monitor loop exiting after drain."
    break
  fi
  sleep "$CHECK_EVERY"
  rotate_logs_if_big
  # Worker mati? restart dengan backoff
  if ! kill -0 "$WPID" 2>/dev/null; then
    log "Worker PID=$WPID not running. Restarting after ${BACKOFF}s..."
    sleep "$BACKOFF"; BACKOFF="$(( BACKOFF<60 ? BACKOFF*2 : 60 ))"
    start_worker
    last_polls=""; last_change_epoch="$(date -u +%s)"
    continue
  fi
  hb_line="$(read_last_heartbeat)"; [ -z "$hb_line" ] && continue
  hb_polls="$(echo "$hb_line" | sed -n 's/.*"polls":[[:space:]]*\([0-9]\+\).*/\1/p' | tail -n1)"
  hb_ts="$(echo "$hb_line" | sed -n 's/.*"ts":[[:space:]]*"\([^"]*\)".*/\1/p' | tail -n1)"
  hb_epoch="$(date -u -d "$hb_ts" +%s 2>/dev/null || date -u +%s)"
  if [ -n "${hb_polls:-}" ] && { [ -z "${last_polls:-}" ] || [ "$hb_polls" -gt "${last_polls:-0}" ]; }; then
    last_polls="$hb_polls"; last_change_epoch="$hb_epoch"; BACKOFF=5
  fi
  now_epoch="$(date -u +%s)"; idle_sec=$(( now_epoch - last_change_epoch ))
  if [ "$idle_sec" -ge "$STALL_SEC" ]; then
    log "No polls increase for ${idle_sec}s (>= ${STALL_SEC}s). Restarting worker..."
    if [ -n "${WPGRP:-}" ]; then kill -TERM -"${WPGRP}" 2>/dev/null || true; else kill -TERM "$WPID" 2>/dev/null || true; fi
    for _ in {1..6}; do kill -0 "$WPID" 2>/dev/null || break; sleep 1; done
    kill -0 "$WPID" 2>/dev/null && { [ -n "${WPGRP:-}" ] && kill -KILL -"${WPGRP}" 2>/dev/null || kill -KILL "$WPID" 2>/dev/null || true; }
    wait "$WPID" 2>/dev/null || true
    start_worker
    last_polls=""; last_change_epoch="$(date -u +%s)"
  fi
done
log "Monitor loop exiting."
exit 0
